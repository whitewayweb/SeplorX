# Supabase PostgreSQL connection string
# Use the "Transaction pooler" URL (port 6543) for Vercel/serverless and local dev
# Use the "Direct connection" URL (port 5432) for migrations (yarn db:migrate)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# 64-char hex string (32 bytes) for AES-256-GCM local encryption
ENCRYPTION_KEY="000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f"

# Better Auth Secret
BETTER_AUTH_SECRET="your-better-auth-secret-here"
BETTER_AUTH_URL="http://localhost:3000"

# AWS KMS Configuration (Optional - Falls back to local AES if missing)
# For SP-API Compliance, use AWS KMS for credential encryption
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."
AWS_KMS_KEY_ID="arn:aws:kms:ap-south-1:..."
